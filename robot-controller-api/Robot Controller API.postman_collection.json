              "});\r",
              "\r",
              "// test response is JSON\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "// test response is array\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    let data = pm.response.json();\r",
              "    pm.expect(data).to.be.an('array');\r",
              "});\r",
              "\r",
              "// test array is not empty\r",
              "pm.test(\"Array is not empty\", function () {\r",
              "    let data = pm.response.json();\r",
              "    pm.expect(data.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// test required fields exist\r",
              "pm.test(\"Each object has required fields\", function () {\r",
              "    let data = pm.response.json();\r",
              "    data.forEach(item => {\r",
              "        pm.expect(item).to.have.property(\"id\");\r",
              "        pm.expect(item).to.have.property(\"name\");\r",
              "        pm.expect(item).to.have.property(\"isMoveCommand\");\r",
              "    });\r",
